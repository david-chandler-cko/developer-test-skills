/// <summary>
/// Shared Arrange+Act in <see cref="InitializeAsync"/>; multiple [Fact] methods assert
/// different aspects of the same result. Split into separate classes when tests need
/// different setup.
///
/// _testScope is a field (not a `using var` local) so the [Fact] methods can query its
/// fakes after Arrange+Act ran in InitializeAsync.
/// </summary>
public class When{{Scenario}} : IAsyncLifetime
{
    private readonly TestContext _testContext;
    private TestScope _testScope = null!;
    private HttpResponseMessage _response = null!;

    public When{{Scenario}}(TestContext testContext)
    {
        _testContext = testContext;
    }

    public async Task InitializeAsync()
    {
        _testScope = _testContext.CreateScope(options =>
        {
            options.ConfigureInterceptor((correlationId, interceptorOptions) =>
            {
                // Register any non-default HTTP interception this scenario needs:
                // interceptorOptions.Register{{NonHappyPath}}Response(correlationId);
            });
        });

        // Seed fakes with starting state, scoped by the test's correlation ID:
        // _testScope.Fake{{Thing}}Store.Add{{Thing}}(_testScope.CorrelationId, new {{Thing}}(...));

        var client = _testScope.CreateApiClient();

        _response = await client.{{MethodCall}};
    }

    [Fact]
    public void ReturnsExpectedStatus()
    {
        _response.StatusCode.Should().Be(HttpStatusCode.{{ExpectedStatus}});
    }

    [Fact]
    public void PersistsThe{{Thing}}()
    {
        _testScope.Get{{Thing}}s().Should().ContainSingle();
    }

    // Add more [Fact] methods for other assertions on the same _response / fake state.

    public Task DisposeAsync()
    {
        _testScope.Dispose();
        return Task.CompletedTask;
    }
}
